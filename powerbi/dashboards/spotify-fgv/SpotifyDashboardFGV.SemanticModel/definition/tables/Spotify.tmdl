		sourceColumn: pct_homens

	column pct_mulheres
		dataType: double
		lineageTag: 20f7a67c-5c77-4f04-8d4b-8bda4317ddf8
		summarizeBy: none
		sourceColumn: pct_mulheres

	column pct_outros
		dataType: double
		lineageTag: ed3cdf83-3c06-4e02-a708-cb7760a9d034
		summarizeBy: none
