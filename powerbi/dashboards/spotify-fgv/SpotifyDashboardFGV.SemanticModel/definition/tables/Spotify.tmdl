	column top_faixa_etaria
		dataType: string
		lineageTag: f71b977e-6164-4d0a-8889-391426d99327
		summarizeBy: none
		sourceColumn: top_faixa_etaria

	partition Spotify = m
		mode: import
		source =
				let
				    Fonte = Csv.Document(File.Contents(PastaDados & "\spotify_dashboard.csv"), [Delimiter=",", Columns=8, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    Promovido = Table.PromoteHeaders(Fonte, [PromoteAllScalars=true]),
				    Tipado = Table.TransformColumnTypes(Promovido, {{"data", type date}, {"programa", type text}, {"plays", Int64.Type}, {"seguidores", Int64.Type}, {"pct_homens", type number}, {"pct_mulheres", type number}, {"pct_outros", type number}, {"top_faixa_etaria", type text}})
				in
				    Tipado

	annotation PBI_ResultType = Table

